# Telegram bot token from @BotFather
BOT_TOKEN=123456789:AA...replace_me

# Flux API base URL (no trailing slash). Local dev example below.
API_BASE_URL=http://127.0.0.1:8123/api/v1

# Flux public website base URL (used for web links: docs, pricing, dashboard).
SITE_URL=http://127.0.0.1:8123

# Default interface language: ru | en
DEFAULT_LANG=ru

# Where to persist user sessions (token per chat).
SESSION_FILE=./data/sessions.json
